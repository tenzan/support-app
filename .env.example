# ============================================================
# Support App — Environment Variables
# ============================================================
# This file documents ALL env vars used by the application.
#
# For Cloudflare Workers, vars are set in different ways:
#   - Bindings (DB, ATTACHMENTS): configured in wrangler.toml
#   - Public vars: set in wrangler.toml [vars] section
#   - Secrets: set via `wrangler secret put <NAME>`
#
# For local dev, create a .dev.vars file in packages/worker/
# with the secrets listed below.
# ============================================================

# --- Secrets (set via `wrangler secret put`) ---

# Resend API key for sending emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend webhook signing secret for verifying inbound email webhooks
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Secret used for session token generation (min 32 chars)
SESSION_SECRET=your-session-secret-min-32-chars

# --- Public vars (set in wrangler.toml [vars]) ---

# From address for outbound support emails
SUPPORT_FROM_EMAIL=support@yourdomain.com

# Domain used for reply-to addresses (reply+<token>@<domain>)
REPLY_TO_DOMAIN=yourdomain.com

# Public URL of the frontend app
APP_URL=https://your-app.pages.dev

# --- Bindings (configured in wrangler.toml, not set as env vars) ---

# DB: D1 database binding (database_name = "support-db")
# ATTACHMENTS: R2 bucket binding (bucket_name = "support-attachments")

# --- Frontend (.env for Vite, if needed) ---

# API base URL (proxied in dev via vite.config.ts)
# VITE_API_URL=http://localhost:8787
