{
  "name": "@support-app/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply support-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply support-db --remote"
  },
  "dependencies": {
    "@support-app/shared": "workspace:*",
    "hono": "^4.6.14",
    "drizzle-orm": "^0.36.4",
    "resend": "^4.1.2",
    "zod": "^3.24.1",
    "@hono/zod-validator": "^0.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
